{
  "name": "cdk-diff-report",
  "version": "1.0.0",
  "description": "Run cdk diff, stream output, and post/update a formatted cost-aware summary comment on Bitbucket, GitHub, or GitLab PRs/MRs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cdk-diff-report": "dist/cli.js"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "dist/*.js.map",
    "dist/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "node --test 'dist/test/*.test.js'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "cdk",
    "diff",
    "cost",
    "pricing",
    "bitbucket",
    "github",
    "gitlab",
    "pull-request",
    "merge-request",
    "aws",
    "cloudformation",
    "devops",
    "infrastructure"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dzon337/cdk-diff-visualizer.git"
  },
  "homepage": "https://github.com/dzon337/cdk-diff-visualizer#readme",
  "dependencies": {
    "@aws-sdk/client-pricing": "^3.1038.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
