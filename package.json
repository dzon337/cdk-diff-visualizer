{
  "name": "cdk-diff-report",
  "version": "1.0.0",
  "description": "Run cdk diff, stream output to console, and post/update a summary comment on your Bitbucket or GitHub PR",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cdk-diff-report": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "node --test 'dist/test/*.test.js'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["cdk", "diff", "bitbucket", "github", "pull-request", "aws", "devops"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=16"
  }
}
